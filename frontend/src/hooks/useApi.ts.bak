      api.put('/profile/preferences', data).then((r) => r.data),
    onSuccess: () => {
      qc.invalidateQueries({ queryKey: ['profile'] });
      qc.invalidateQueries({ queryKey: ['auth', 'me'] });
    },
  });
};

export const useUpdateAvatar = () => {
