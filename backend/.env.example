# ===========================
# NucleoIA V4 - Backend Environment Variables
# ===========================
# Copy this file to .env and fill in the real values
# NEVER commit .env to git!

NODE_ENV=production
PORT=3001
FRONTEND_URL=https://painel.nucleoia.online

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nucleoia_db"

# JWT Authentication
JWT_SECRET="generate-a-random-64-char-secret-here"
JWT_REFRESH_SECRET="generate-another-random-64-char-secret-here"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File uploads
UPLOAD_PATH=/var/www/nucleoia/backend/uploads
MAX_FILE_SIZE=10485760

# Backups
BACKUP_PATH=/var/www/nucleoia/backups
BACKUP_RETENTION_DAYS=30
