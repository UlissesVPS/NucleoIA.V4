// Bulk import prompts (admin only)
export const bulkImportPrompts = async (req: AuthRequest, res: Response) => {
  try {
    const { prompts: promptsData } = req.body;

    if (!Array.isArray(promptsData) || promptsData.length === 0) {
      return errorResponse(res, 'INVALID_DATA', 'Nenhum prompt para importar', 400);
    }

    if (promptsData.length > 500) {
      return errorResponse(res, 'TOO_MANY', 'Maximo de 500 prompts por importacao', 400);
    }

    // Collect unique category names from prompts
    const categoryNames = [...new Set(promptsData.map((p: any) => p.category_name || 'Outros'))];

    // Get or create categories
    const categoryMap: Record<string, string> = {};
    for (const name of categoryNames) {
      const slug = name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

      let category = await prisma.category.findFirst({
        where: {
          OR: [
            { name: { equals: name, mode: 'insensitive' } },
            { slug: slug },
          ],
        },
      });

      if (!category) {
        category = await prisma.category.create({
          data: { name, slug: slug || 'outros-' + Date.now() },
        });
      }

      categoryMap[name] = category.id;
    }

    // Import prompts in batches
    const results = { imported: 0, errors: 0, errorDetails: [] as string[] };
    const authorId = req.user!.id;

    // Use createMany for performance (batch of all prompts)
    const promptsToCreate = promptsData.map((p: any, i: number) => {
      const catName = p.category_name || 'Outros';
      const categoryId = categoryMap[catName] || categoryMap['Outros'];
      const rawType = String(p.type || 'image').toUpperCase();
      const type = rawType === 'VIDEO' ? 'VIDEO' : 'IMAGE';

      return {
        title: String(p.title || `Prompt ${i + 1}`).substring(0, 200),
        type: type as 'IMAGE' | 'VIDEO',
        categoryId,
        content: String(p.content || ''),
        description: p.description ? String(p.description).substring(0, 500) : null,
        thumbnailUrl: p.thumbnail_url || p.thumbnailUrl || null,
        mediaUrl: p.media_url || p.mediaUrl || null,
        tags: Array.isArray(p.tags) ? p.tags : [],
        authorId,
        isCommunity: false,
      };
    });

    // Use createMany for batch insert
    const result = await prisma.prompt.createMany({
      data: promptsToCreate,
      skipDuplicates: true,
    });

    results.imported = result.count;

    // Update category counts
    for (const [name, catId] of Object.entries(categoryMap)) {
      const count = promptsToCreate.filter((p: any) => p.categoryId === catId).length;
      if (count > 0) {
        await prisma.category.update({
          where: { id: catId },
          data: { promptCount: { increment: count } },
        });
      }
    }

    // Log activity
    await prisma.activityLog.create({
      data: {
        userId: authorId,
        type: 'ADMIN',
        description: `Importacao em massa: ${results.imported} prompts importados`,
        ipAddress: req.ip,
        metadata: {
          imported: results.imported,
          categories: Object.keys(categoryMap),
        },
      },
    });

    // Fire webhook
    fireWebhookEvent('prompt.bulk_imported', {
      count: results.imported,
      categories: Object.keys(categoryMap),
    });

    return successResponse(res, {
      imported: results.imported,
      errors: results.errors,
      errorDetails: results.errorDetails,
      categoriesUsed: Object.keys(categoryMap),
    }, undefined, 201);
  } catch (error) {
    console.error('[BulkImport] Error:', error);
    return errorResponse(res, 'BULK_IMPORT_ERROR', 'Erro ao importar prompts em massa', 500);
  }
};

// Download and optimize external images locally
export const downloadImages = async (req: AuthRequest, res: Response) => {
  try {
    const { images } = req.body;

    if (!Array.isArray(images) || images.length === 0) {
      return errorResponse(res, 'INVALID_DATA', 'Nenhuma imagem para baixar', 400);
    }

    if (images.length > 200) {
      return errorResponse(res, 'TOO_MANY', 'Maximo de 200 imagens por request', 400);
    }

    const uploadsDir = path.join(__dirname, '../../uploads/thumbnails');
    if (!fs.existsSync(uploadsDir)) {
      fs.mkdirSync(uploadsDir, { recursive: true });
    }

    const results: Array<{ original_url: string; local_url: string; success: boolean; error?: string }> = [];

    // Process in batches of 5
    const batchSize = 5;
    for (let i = 0; i < images.length; i += batchSize) {
      const batch = images.slice(i, i + batchSize);
      const batchResults = await Promise.allSettled(
        batch.map(async (img: { url: string; filename_hint?: string }) => {
          const originalUrl = img.url;
          try {
            // Fetch image with timeout
            const controller = new AbortController();
            const timeout = setTimeout(() => controller.abort(), 15000);

            const response = await fetch(originalUrl, {
              signal: controller.signal,
              headers: {
                'User-Agent': 'Mozilla/5.0 (compatible; NucleoIA/1.0)',
              },
            });
            clearTimeout(timeout);

            if (!response.ok) {
              throw new Error(`HTTP ${response.status}`);
            }

            const buffer = Buffer.from(await response.arrayBuffer());

            // Optimize with sharp: resize max 800px, convert to webp
            const uuid = uuidv4();
            const filename = `${uuid}.webp`;
            const filepath = path.join(uploadsDir, filename);

            await sharp(buffer)
              .resize(800, 800, { fit: 'inside', withoutEnlargement: true })
              .webp({ quality: 85 })
              .toFile(filepath);

            const localUrl = `/uploads/thumbnails/${filename}`;

            return { original_url: originalUrl, local_url: localUrl, success: true };
          } catch (err: any) {
            return {
              original_url: originalUrl,
              local_url: '',
              success: false,
              error: err.message || 'Download failed',
            };
          }
        })
      );

      for (const result of batchResults) {
        if (result.status === 'fulfilled') {
          results.push(result.value);
        } else {
          results.push({
            original_url: 'unknown',
            local_url: '',
            success: false,
            error: result.reason?.message || 'Promise rejected',
          });
        }
      }
    }

    const successCount = results.filter(r => r.success).length;
    const errorCount = results.filter(r => !r.success).length;

    console.log(`[DownloadImages] ${successCount} downloaded, ${errorCount} errors`);

    return successResponse(res, {
      total: results.length,
      downloaded: successCount,
      errors: errorCount,
      results,
    });
  } catch (error) {
    console.error('[DownloadImages] Error:', error);
    return errorResponse(res, 'DOWNLOAD_ERROR', 'Erro ao baixar imagens', 500);
  }
};