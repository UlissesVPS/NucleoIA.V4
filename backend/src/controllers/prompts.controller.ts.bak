import { fireWebhookEvent } from '../services/webhook.service';
import { Response } from 'express';
import { notifyMembers } from "../services/notification.service";
import prisma from '../config/database';
import { successResponse, errorResponse } from '../utils/response';
import { AuthRequest } from '../middleware/auth.middleware';
import sharp from 'sharp';
import { v4 as uuidv4 } from 'uuid';
import path from 'path';
import fs from 'fs';

export const listPrompts = async (req: AuthRequest, res: Response) => {
  try {
    const page = parseInt(req.query.page as string) || 1;
    const limit = parseInt(req.query.limit as string) || 20;
    const type = req.query.type as string;
    const category = req.query.category as string;
    const search = req.query.search as string;

    const where: any = { isCommunity: false };

    if (type) where.type = type;
    if (category) where.categoryId = category;
    if (search) {
      where.OR = [
        { title: { contains: search, mode: 'insensitive' } },
        { description: { contains: search, mode: 'insensitive' } },
      ];
    }

    const [prompts, total] = await Promise.all([
      prisma.prompt.findMany({
        where,
        include: {
          category: true,
          author: { select: { id: true, name: true } },
          promptLikes: { where: { userId: req.user!.id } },
        },
        skip: (page - 1) * limit,
        take: limit,
        orderBy: { createdAt: 'asc' },
      }),
      prisma.prompt.count({ where }),
    ]);

    return successResponse(
      res,
      prompts.map((p) => ({
        id: p.id,
        title: p.title,
        type: p.type,
        category: p.category.name,
        categoryId: p.categoryId,
        content: p.content,
        thumbnailUrl: p.thumbnailUrl,
        mediaUrl: p.mediaUrl,
        likes: p.likes,
        author: p.author.name,
        createdAt: p.createdAt,
        description: p.description,
        tags: p.tags,
        liked: p.promptLikes.length > 0,
      })),
      { total, page, limit, totalPages: Math.ceil(total / limit) }
    );
  } catch (error) {
    return errorResponse(res, 'PROMPTS_LIST_ERROR', 'Erro ao listar prompts', 500);
  }
};

export const getPrompt = async (req: AuthRequest, res: Response) => {
  try {
    const { id } = req.params;

    const prompt = await prisma.prompt.findUnique({
      where: { id },
      include: {
        category: true,
        author: { select: { id: true, name: true } },
        promptLikes: { where: { userId: req.user!.id } },
      },
    });

    if (!prompt) {
      return errorResponse(res, 'PROMPT_NOT_FOUND', 'Prompt nao encontrado', 404);
    }

    return successResponse(res, {
      id: prompt.id,
      title: prompt.title,
      type: prompt.type,
      category: prompt.category.name,
      categoryId: prompt.categoryId,
      content: prompt.content,
      description: prompt.description,
      thumbnailUrl: prompt.thumbnailUrl,
      mediaUrl: prompt.mediaUrl,
      tags: prompt.tags,
      likes: prompt.likes,
      author: prompt.author.name,
      authorId: prompt.authorId,
      createdAt: prompt.createdAt,
      liked: prompt.promptLikes.length > 0,
    });
  } catch (error) {
    return errorResponse(res, 'PROMPT_GET_ERROR', 'Erro ao buscar prompt', 500);
  }
};

export const createPrompt = async (req: AuthRequest, res: Response) => {
  try {
    const { title, type, categoryId, content, description, thumbnailUrl, mediaUrl, tags } = req.body;

    const prompt = await prisma.prompt.create({
      data: {
        title,
        type,
        categoryId,
        content,
        description,
        thumbnailUrl,
        mediaUrl,
        tags: tags || [],
        authorId: req.user!.id,
        isCommunity: false,
      },
    });

    // Update category count
    await prisma.category.update({
      where: { id: categoryId },
      data: { promptCount: { increment: 1 } },
    });

    // Notify members about new prompt (async, don't block response)
    notifyMembers({
      type: 'NEW_PROMPT',
      title: title,
      message: description || 'Novos prompts foram adicionados a biblioteca. Confira agora\!',
      link: '/prompts',
    }).catch(() => {});

    // Fire webhook
    fireWebhookEvent('prompt.created', { id: prompt.id, title: prompt.title, type: prompt.type, categoryId: prompt.categoryId });

    return successResponse(res, prompt, undefined, 201);
  } catch (error) {
    return errorResponse(res, 'PROMPT_CREATE_ERROR', 'Erro ao criar prompt', 500);
  }
};

export const updatePrompt = async (req: AuthRequest, res: Response) => {
  try {
    const { id } = req.params;
    const { title, type, categoryId, content, description, thumbnailUrl, mediaUrl, tags } = req.body;

    const prompt = await prisma.prompt.update({
      where: { id },
      data: {
        title,
        type,
        categoryId,
        content,
        description,
        thumbnailUrl,
        mediaUrl,
        tags,
      },
    });

    // Fire webhook
    fireWebhookEvent('prompt.updated', { id: prompt.id, title: prompt.title, type: prompt.type });

    return successResponse(res, prompt);
  } catch (error) {
    return errorResponse(res, 'PROMPT_UPDATE_ERROR', 'Erro ao atualizar prompt', 500);
  }
};

export const deletePrompt = async (req: AuthRequest, res: Response) => {
  try {
    const { id } = req.params;

    const prompt = await prisma.prompt.findUnique({ where: { id } });
    if (!prompt) {
      return errorResponse(res, 'PROMPT_NOT_FOUND', 'Prompt nao encontrado', 404);
    }

    await prisma.prompt.delete({ where: { id } });

    // Update category count
    await prisma.category.update({
      where: { id: prompt.categoryId },
      data: { promptCount: { decrement: 1 } },
    });

    // Fire webhook
    fireWebhookEvent('prompt.deleted', { id: prompt.id, title: prompt.title });

    return successResponse(res, { message: 'Prompt deletado com sucesso' });
  } catch (error) {
    return errorResponse(res, 'PROMPT_DELETE_ERROR', 'Erro ao deletar prompt', 500);
  }
};

export const toggleLike = async (req: AuthRequest, res: Response) => {
  try {
    const { id } = req.params;
    const userId = req.user!.id;

    const existingLike = await prisma.promptLike.findUnique({
      where: { userId_promptId: { userId, promptId: id } },
    });

    if (existingLike) {
      await prisma.promptLike.delete({
        where: { id: existingLike.id },
      });
      await prisma.prompt.update({
        where: { id },
        data: { likes: { decrement: 1 } },
      });
      return successResponse(res, { liked: false });
    } else {
      await prisma.promptLike.create({
        data: { userId, promptId: id },
      });
      await prisma.prompt.update({
        where: { id },
        data: { likes: { increment: 1 } },
      });
      return successResponse(res, { liked: true });
    }
  } catch (error) {
    return errorResponse(res, 'LIKE_ERROR', 'Erro ao processar like', 500);
  }
};

export const copyPrompt = async (req: AuthRequest, res: Response) => {
  try {
    const { id } = req.params;

    await prisma.activityLog.create({
      data: {
        userId: req.user!.id,
        type: 'COPY',
        description: 'Prompt copiado',
        ipAddress: req.ip,
        metadata: { promptId: id },
      },
    });

    return successResponse(res, { copied: true });
  } catch (error) {
    return errorResponse(res, 'COPY_ERROR', 'Erro ao registrar copia', 500);
  }
};

// Community prompts
export const getMyPrompts = async (req: AuthRequest, res: Response) => {
  try {
    const prompts = await prisma.prompt.findMany({
      where: { authorId: req.user!.id, isCommunity: true },
      include: { category: true },
      orderBy: { createdAt: 'asc' },
    });

    return successResponse(res, prompts);
  } catch (error) {
    return errorResponse(res, 'MY_PROMPTS_ERROR', 'Erro ao buscar seus prompts', 500);
  }
};

